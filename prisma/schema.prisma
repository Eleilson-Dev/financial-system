// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum PaymentMethod {
  CREDIT
  DEBIT
  PIX
  CASH
}

enum CashStatus {
  OPEN
  CLOSED
}

enum UserRole {
  OWNER
  ADMIN
  OPERATOR
}

enum CashRegisterStatus {
  OPEN
  CLOSED
}

enum ExpenseCategory {
  MERCHANDISE
  FIXED
  TAX
  MAINTENANCE
  OTHER
}

enum SalaryStatus {
  PAID
}

enum TransactionDirection {
  IN
  OUT
}

enum TransactionType {
  INCOME
  EXPENSE
  SALARY_PAYMENT
  SALE
  ADJUSTMENT
}

enum CashRegisterEntryReferenceType {
  SALE
  CUSTOMER_ACCOUNT
  MANUAL_ADJUST
  TRANSFER
}

enum CustomerTransactionReferenceType {
  DEBT
  PAYMENT
}

model Company {
  id        String   @id @default(uuid())
  name      String
  document  String   @unique
  createdAt DateTime @default(now())

  users            User[]
  expenses         Expense[]
  cashRegisters    CashRegister[]
  sales            Sale[]
  employees        Employee[]
  monthlyClosures  MonthlyClosure[]
  salaryPayments   SalaryPayment[]
  cashAccount      CashAccount?
  customers        Customer[]
  customerAccounts CustomerAccount[]
}

model User {
  id       String   @id @default(uuid())
  name     String
  email    String   @unique
  password String
  role     UserRole
  isActive Boolean  @default(true)

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  expensesCreated Expense[] @relation("UserExpenses")

  openedCashRegisters CashRegister[] @relation("OpenedCash")
  closedCashRegisters CashRegister[] @relation("ClosedCash")

  salaryPayments SalaryPayment[] @relation("UserSalaryPayments")

  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  sales                   Sale[]
  monthlyClosures         MonthlyClosure[]
  employeeSalaryHistories EmployeeSalaryHistory[]
  cashAccountTransactions CashAccountTransaction[]
}

model CashAccount {
  id      String  @id @default(uuid())
  balance Decimal @db.Decimal(12, 2)

  companyId String  @unique
  company   Company @relation(fields: [companyId], references: [id])

  updatedAt               DateTime                 @updatedAt
  cashAccountTransactions CashAccountTransaction[]
}

model CashAccountTransaction {
  id            String      @id @default(uuid())
  cashAccountId String
  cashAccount   CashAccount @relation(fields: [cashAccountId], references: [id])

  direction   TransactionDirection // IN | OUT
  type        TransactionType // INCOME | EXPENSE | SALARY_PAYMENT | SALE
  amount      Decimal              @db.Decimal(12, 2)
  description String?
  createdAt   DateTime             @default(now())

  referenceMonth Int
  referenceYear  Int

  referenceId String?

  performedById String?
  performedBy   User?   @relation(fields: [performedById], references: [id])
}

model Expense {
  id          String          @id @default(uuid())
  description String
  amount      Decimal         @db.Decimal(10, 2)
  category    ExpenseCategory
  createdAt   DateTime        @default(now())

  referenceMonth Int // 1 a 12
  referenceYear  Int

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  createdById String?
  createdBy   User?   @relation("UserExpenses", fields: [createdById], references: [id])
}

model CashRegister {
  id String @id @default(uuid())

  openedAt DateTime  @default(now())
  closedAt DateTime?

  openingAmount Decimal @db.Decimal(12, 2)

  // Totais por forma de pagamento
  totalCash   Decimal @default(0) @db.Decimal(12, 2)
  totalPix    Decimal @default(0) @db.Decimal(12, 2)
  totalDebit  Decimal @default(0) @db.Decimal(12, 2)
  totalCredit Decimal @default(0) @db.Decimal(12, 2)

  // Total geral de entradas
  totalInflow Decimal @default(0) @db.Decimal(12, 2)

  closingAmount Decimal? @db.Decimal(12, 2)

  status CashRegisterStatus @default(OPEN)

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  openedById String
  openedBy   User   @relation("OpenedCash", fields: [openedById], references: [id])

  closedById String?
  closedBy   User?   @relation("ClosedCash", fields: [closedById], references: [id])

  entries CashRegisterEntry[]
}

model CashRegisterEntry {
  id String @id @default(uuid())

  amount        Decimal              @db.Decimal(10, 2)
  direction     TransactionDirection // IN | OUT
  paymentMethod PaymentMethod?
  description   String?
  createdAt     DateTime             @default(now())

  referenceMonth Int
  referenceYear  Int

  cashRegisterId String
  cashRegister   CashRegister @relation(fields: [cashRegisterId], references: [id])

  referenceType CashRegisterEntryReferenceType?
  referenceId   String?
}

model Sale {
  id String @id @default(uuid())

  amount        Decimal       @db.Decimal(10, 2)
  paymentMethod PaymentMethod
  createdAt     DateTime      @default(now())

  referenceMonth Int
  referenceYear  Int

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])
}

model Employee {
  id       String  @id @default(uuid())
  name     String
  salary   Decimal @db.Decimal(10, 2)
  isActive Boolean @default(true)
  cpf      String  @unique

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  salaryPayments SalaryPayment[]

  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt
  terminatedAt            DateTime?
  employeeSalaryHistories EmployeeSalaryHistory[]
}

model SalaryPayment {
  id     String   @id @default(uuid())
  amount Decimal  @db.Decimal(10, 2)
  paidAt DateTime @default(now())

  referenceMonth Int // 1 a 12
  referenceYear  Int

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  paidByUserId String
  paidByUser   User   @relation("UserSalaryPayments", fields: [paidByUserId], references: [id])
}

model EmployeeSalaryHistory {
  id         String   @id @default(uuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])

  oldSalary Decimal @db.Decimal(10, 2)
  newSalary Decimal @db.Decimal(10, 2)
  increase  Decimal @db.Decimal(10, 2)

  reason    String?
  changedAt DateTime @default(now())

  changedById String?
  changedBy   User?   @relation(fields: [changedById], references: [id])
}

model MonthlyClosure {
  id String @id @default(uuid())

  // Mês de competência
  month Int
  year  Int

  // Período real considerado
  periodStart DateTime
  periodEnd   DateTime

  totalRevenue  Decimal @db.Decimal(12, 2)
  totalExpenses Decimal @db.Decimal(12, 2)
  totalSalaries Decimal @db.Decimal(12, 2)
  profit        Decimal @db.Decimal(12, 2)

  isEarlyClosure Boolean  @default(false)
  closedAt       DateTime @default(now())

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  closedById String
  closedBy   User   @relation(fields: [closedById], references: [id])

  @@unique([month, year, companyId])
}

model Customer {
  id    String  @id @default(uuid())
  name  String
  cpf   String  @unique
  phone String?

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  account CustomerAccount?

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  customerDebts CustomerDebt[]
}

model CustomerAccount {
  id      String  @id @default(uuid())
  balance Decimal @default(0) @db.Decimal(12, 2)

  customerId String   @unique
  customer   Customer @relation(fields: [customerId], references: [id])

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactions CustomerAccountTransaction[]
}

model CustomerDebt {
  id         String   @id @default(uuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  referenceMonth Int
  referenceYear  Int

  amount      Decimal  @db.Decimal(12, 2)
  createdAt   DateTime @default(now())
  description String?
}

model CustomerAccountTransaction {
  id          String               @id @default(uuid())
  amount      Decimal              @db.Decimal(10, 2)
  direction   TransactionDirection
  description String?
  createdAt   DateTime             @default(now())

  referenceMonth Int
  referenceYear  Int

  customerAccountId String
  customerAccount   CustomerAccount @relation(fields: [customerAccountId], references: [id])

  referenceType CustomerTransactionReferenceType?
  referenceId   String?
}
