// ======================================================
// PRISMA CONFIGURATION
// ======================================================
// Configuração do cliente Prisma que será gerado para uso
// dentro da aplicação Node.js / TypeScript.

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

// ======================================================
// DATABASE CONNECTION
// ======================================================
// Define o banco de dados utilizado pelo sistema.
// Aqui está configurado para PostgreSQL.

datasource db {
  provider = "postgresql"
}

// ======================================================
// ENUMS (TIPOS FIXOS DO SISTEMA)
// ======================================================

// Formas de pagamento aceitas pelo sistema
enum PaymentMethod {
  CREDIT
  DEBIT
  PIX
  CASH
  ACCOUNT
}

// Status de um caixa
enum CashStatus {
  OPEN
  CLOSED
}

// Papéis de usuários dentro da empresa
enum UserRole {
  OWNER
  ADMIN
  OPERATOR
}

// Status operacional do caixa
enum CashRegisterStatus {
  OPEN
  CLOSED
}

// Categorias de despesas da empresa
enum ExpenseCategory {
  MERCHANDISE
  FIXED
  TAX
  MAINTENANCE
  OTHER
}

// Status de pagamento de salário
enum SalaryStatus {
  PAID
}

// Direção de uma transação financeira
enum TransactionDirection {
  IN
  OUT
}

// Tipo da transação financeira
enum TransactionType {
  INCOME
  EXPENSE
  SALARY_PAYMENT
  SALE
  ADJUSTMENT
}

// Origem de uma movimentação dentro do caixa
enum CashRegisterEntryReferenceType {
  SALE
  CUSTOMER_ACCOUNT
  MANUAL_ADJUST
  TRANSFER
}

// Tipo de referência da conta de cliente
enum CustomerTransactionReferenceType {
  DEBT
  PAYMENT
}

enum StockType {
  UNIT // estoque por unidade
  KG // estoque por quilo
}

enum StockMovementType {
  SALE // venda
  ADD // reposição
  LOSS // estragou/descarte
}

// ======================================================
// COMPANY (EMPRESA)
// ======================================================
// A empresa é o núcleo do sistema.
// Tudo pertence a uma empresa.
//
// Isso permite que o sistema seja multi-empresa
// (várias empresas usando o mesmo sistema).

model Company {
  id        String   @id @default(uuid())
  name      String
  document  String   @unique
  createdAt DateTime @default(now())

  // Relações principais da empresa
  users            User[]
  expenses         Expense[]
  cashRegisters    CashRegister[]
  sales            Sale[]
  employees        Employee[]
  monthlyClosures  MonthlyClosure[]
  salaryPayments   SalaryPayment[]
  cashAccount      CashAccount?
  customers        Customer[]
  customerAccounts CustomerAccount[]

  products          Product[]
  productCategories ProductCategory[]
}

// ======================================================
// USER (USUÁRIOS DO SISTEMA)
// ======================================================
// Representa qualquer pessoa que utiliza o sistema
// dentro da empresa.

model User {
  id       String   @id @default(uuid())
  name     String
  email    String   @unique
  password String
  role     UserRole
  isActive Boolean  @default(true)

  // Empresa a qual o usuário pertence
  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  // Despesas criadas pelo usuário
  expensesCreated Expense[] @relation("UserExpenses")

  // Caixas abertos por este usuário
  openedCashRegisters CashRegister[] @relation("OpenedCash")

  // Caixas fechados por este usuário
  closedCashRegisters CashRegister[] @relation("ClosedCash")

  // Salários pagos por este usuário
  salaryPayments SalaryPayment[] @relation("UserSalaryPayments")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Vendas registradas pelo usuário
  sales Sale[]

  // Fechamentos mensais realizados pelo usuário
  monthlyClosures MonthlyClosure[]

  // Alterações de salário feitas pelo usuário
  employeeSalaryHistories EmployeeSalaryHistory[]

  // Transações feitas na conta da empresa
  cashAccountTransactions CashAccountTransaction[]
}

// ======================================================
// CONTA FINANCEIRA DA EMPRESA
// ======================================================
// Representa a conta geral da empresa.
// Pode ser entendida como o "saldo geral".

model CashAccount {
  id      String  @id @default(uuid())
  balance Decimal @db.Decimal(12, 2)

  companyId String  @unique
  company   Company @relation(fields: [companyId], references: [id])

  updatedAt DateTime @updatedAt

  // Histórico de movimentações financeiras
  cashAccountTransactions CashAccountTransaction[]
}

// ======================================================
// TRANSAÇÕES DA CONTA DA EMPRESA
// ======================================================
// Registro de entradas e saídas da conta financeira.

model CashAccountTransaction {
  id            String      @id @default(uuid())
  cashAccountId String
  cashAccount   CashAccount @relation(fields: [cashAccountId], references: [id])

  direction   TransactionDirection
  type        TransactionType
  amount      Decimal              @db.Decimal(12, 2)
  description String?
  createdAt   DateTime             @default(now())

  referenceMonth Int
  referenceYear  Int

  referenceId String?

  // Usuário responsável pela transação
  performedById String?
  performedBy   User?   @relation(fields: [performedById], references: [id])

  @@index([cashAccountId, createdAt])
  @@index([referenceMonth, referenceYear])
}

// ======================================================
// DESPESAS DA EMPRESA
// ======================================================

model Expense {
  id          String          @id @default(uuid())
  description String
  amount      Decimal         @db.Decimal(10, 2)
  category    ExpenseCategory
  createdAt   DateTime        @default(now())

  referenceMonth Int
  referenceYear  Int

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  createdById String?
  createdBy   User?   @relation("UserExpenses", fields: [createdById], references: [id])
}

// ======================================================
// CAIXA OPERACIONAL (PDV)
// ======================================================
// Representa o caixa aberto durante o expediente.

model CashRegister {
  id String @id @default(uuid())

  openedAt DateTime  @default(now())
  closedAt DateTime?

  openingAmount Decimal @default(0) @db.Decimal(12, 2)

  // Totais por forma de pagamento
  totalCash   Decimal @default(0) @db.Decimal(12, 2)
  totalPix    Decimal @default(0) @db.Decimal(12, 2)
  totalDebit  Decimal @default(0) @db.Decimal(12, 2)
  totalCredit Decimal @default(0) @db.Decimal(12, 2)

  totalInflow Decimal @default(0) @db.Decimal(12, 2)

  closingAmount Decimal? @db.Decimal(12, 2)

  status CashRegisterStatus @default(OPEN)

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  openedById String
  openedBy   User   @relation("OpenedCash", fields: [openedById], references: [id])

  closedById String?
  closedBy   User?   @relation("ClosedCash", fields: [closedById], references: [id])

  countedCashAmount  Decimal? @default(0) @db.Decimal(12, 2)
  expectedCashAmount Decimal? @default(0) @db.Decimal(12, 2)
  cashDifference     Decimal? @default(0) @db.Decimal(12, 2)

  // Movimentações realizadas dentro do caixa
  entries CashRegisterEntry[]
}

// ======================================================
// MOVIMENTAÇÃO DO CAIXA
// ======================================================

model CashRegisterEntry {
  id String @id @default(uuid())

  amount        Decimal              @db.Decimal(10, 2)
  direction     TransactionDirection
  paymentMethod PaymentMethod?
  description   String?
  createdAt     DateTime             @default(now())

  referenceMonth Int
  referenceYear  Int

  cashRegisterId String
  cashRegister   CashRegister @relation(fields: [cashRegisterId], references: [id])

  referenceType CashRegisterEntryReferenceType?
  referenceId   String?

  @@index([cashRegisterId, createdAt])
  @@index([referenceMonth, referenceYear])
}

// ======================================================
// CATEGORIAS DE PRODUTOS (DINÂMICAS)
// ======================================================

model ProductCategory {
  id             String @id @default(uuid())
  name           String
  nameNormalized String

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  products Product[]

  createdAt DateTime @default(now())

  @@unique([name, companyId])
}

// ======================================================
// PRODUTOS
// ======================================================

model Product {
  id   String @id @default(uuid())
  name String

  price   Decimal @db.Decimal(10, 2) // preço base (unitário OU por kg)
  barcode String

  stock     Decimal?  @db.Decimal(10, 2)
  stockType StockType @default(UNIT) // UNIT | KG

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  categoryId String?
  category   ProductCategory? @relation(fields: [categoryId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  saleItems      SaleItem[]
  stockMovements StockMovement[]

  @@unique([barcode, companyId])
  @@index([companyId])
  @@index([barcode])
}

model StockMovement {
  id        String            @id @default(uuid())
  productId String
  product   Product           @relation(fields: [productId], references: [id])
  type      StockMovementType

  unitType StockType?

  quantity  Decimal  @db.Decimal(10, 2)
  createdAt DateTime @default(now())
}

// ======================================================
// VENDAS
// ======================================================

model Sale {
  id String @id @default(uuid())

  amount        Decimal       @db.Decimal(10, 2)
  paymentMethod PaymentMethod
  createdAt     DateTime      @default(now())

  referenceMonth Int
  referenceYear  Int

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])

  items SaleItem[]

  @@index([companyId, createdAt])
  @@index([referenceMonth, referenceYear, companyId])
}

// ======================================================
// ITENS DA VENDA (PRODUTOS OU AVULSO)
// ======================================================

model SaleItem {
  id String @id @default(uuid())

  saleId String
  sale   Sale   @relation(fields: [saleId], references: [id])

  productId String? // NULL para produtos avulsos
  product   Product? @relation(fields: [productId], references: [id])

  nameSnapshot         String // sempre preencher: nome do produto ou "Venda Avulsa"
  categoryId           String? // NULL para produtos avulsos
  categoryNameSnapshot String? // NULL ou "Avulso"

  quantity  Decimal @db.Decimal(10, 3)
  unitPrice Decimal @db.Decimal(10, 2)
  total     Decimal @db.Decimal(10, 2) // quantity * unitPrice

  createdAt DateTime @default(now())

  @@index([saleId])
  @@index([productId])
  @@index([categoryId])
}

// ======================================================
// FUNCIONÁRIOS
// ======================================================

model Employee {
  id       String  @id @default(uuid())
  name     String
  salary   Decimal @db.Decimal(10, 2)
  isActive Boolean @default(true)
  cpf      String  @unique

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  salaryPayments SalaryPayment[]

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  terminatedAt DateTime?

  employeeSalaryHistories EmployeeSalaryHistory[]
}

// ======================================================
// PAGAMENTO DE SALÁRIOS
// ======================================================

model SalaryPayment {
  id     String   @id @default(uuid())
  amount Decimal  @db.Decimal(10, 2)
  paidAt DateTime @default(now())

  referenceMonth Int
  referenceYear  Int

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  paidByUserId String
  paidByUser   User   @relation("UserSalaryPayments", fields: [paidByUserId], references: [id])
}

// ======================================================
// HISTÓRICO DE SALÁRIO
// ======================================================

model EmployeeSalaryHistory {
  id         String   @id @default(uuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])

  oldSalary Decimal @db.Decimal(10, 2)
  newSalary Decimal @db.Decimal(10, 2)
  increase  Decimal @db.Decimal(10, 2)

  reason    String?
  changedAt DateTime @default(now())

  changedById String?
  changedBy   User?   @relation(fields: [changedById], references: [id])
}

// ======================================================
// FECHAMENTO MENSAL FINANCEIRO
// ======================================================

model MonthlyClosure {
  id String @id @default(uuid())

  month Int
  year  Int

  periodStart DateTime
  periodEnd   DateTime

  totalRevenue  Decimal @db.Decimal(12, 2)
  totalExpenses Decimal @db.Decimal(12, 2)
  totalSalaries Decimal @db.Decimal(12, 2)
  profit        Decimal @db.Decimal(12, 2)

  isEarlyClosure Boolean  @default(false)
  closedAt       DateTime @default(now())

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  closedById String
  closedBy   User   @relation(fields: [closedById], references: [id])

  @@unique([month, year, companyId])
}

// ======================================================
// CLIENTES
// ======================================================

model Customer {
  id             String  @id @default(uuid())
  name           String
  nameNormalized String  @db.VarChar(255)
  cpf            String  @unique
  phone          String?

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  account CustomerAccount?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customerDebts CustomerDebt[]

  address Json?

  @@index([companyId, nameNormalized])
}

// ======================================================
// CONTA FINANCEIRA DO CLIENTE
// ======================================================

model CustomerAccount {
  id      String  @id @default(uuid())
  balance Decimal @default(0) @db.Decimal(12, 2)

  customerId String   @unique
  customer   Customer @relation(fields: [customerId], references: [id])

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactions CustomerAccountTransaction[]
}

// ======================================================
// DÍVIDAS DO CLIENTE
// ======================================================

model CustomerDebt {
  id         String   @id @default(uuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  referenceMonth Int
  referenceYear  Int

  amount      Decimal  @db.Decimal(12, 2)
  createdAt   DateTime @default(now())
  description String?
}

// ======================================================
// MOVIMENTAÇÃO DA CONTA DO CLIENTE
// ======================================================

model CustomerAccountTransaction {
  id          String               @id @default(uuid())
  amount      Decimal              @db.Decimal(10, 2)
  direction   TransactionDirection
  description String?
  createdAt   DateTime             @default(now())

  referenceMonth Int
  referenceYear  Int

  customerAccountId String
  customerAccount   CustomerAccount @relation(fields: [customerAccountId], references: [id])

  referenceType CustomerTransactionReferenceType?
  referenceId   String?
}
