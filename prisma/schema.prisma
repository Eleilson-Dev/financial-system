// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum PaymentMethod {
  CREDIT
  DEBIT
  PIX
  CASH
}

enum CashStatus {
  OPEN
  CLOSED
}

enum UserRole {
  OWNER
  ADMIN
  OPERATOR
}

enum ExpenseCategory {
  MERCHANDISE
  FIXED
  TAX
  MAINTENANCE
  OTHER
}

model Company {
  id        String   @id @default(uuid())
  name      String
  document  String   @unique
  createdAt DateTime @default(now())

  users           User[]
  expenses        Expense[]
  cashRegisters   CashRegister[]
  sales           Sale[]
  employees       Employee[]
  monthlyClosures MonthlyClosure[]
  salaryPayments  SalaryPayment[]
}

model Expense {
  id          String          @id @default(uuid())
  description String
  amount      Decimal         @db.Decimal(10, 2)
  category    ExpenseCategory
  createdAt   DateTime        @default(now())

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  createdById String?
  createdBy   User?   @relation("UserExpenses", fields: [createdById], references: [id])
}

model User {
  id       String   @id @default(uuid())
  name     String
  email    String   @unique
  password String
  role     UserRole
  isActive Boolean  @default(true)

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  expensesCreated Expense[] @relation("UserExpenses")

  openedCashRegisters CashRegister[] @relation("OpenedCash")
  closedCashRegisters CashRegister[] @relation("ClosedCash")

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  sales           Sale[]
  monthlyClosures MonthlyClosure[]
}

model CashRegister {
  id            String    @id @default(uuid())
  openedAt      DateTime  @default(now())
  closedAt      DateTime?
  openingAmount Decimal   @db.Decimal(10, 2)
  closingAmount Decimal?  @db.Decimal(10, 2)

  status CashStatus @default(OPEN)

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  openedById String
  openedBy   User   @relation("OpenedCash", fields: [openedById], references: [id])

  closedById String?
  closedBy   User?   @relation("ClosedCash", fields: [closedById], references: [id])

  sales Sale[]
}

model Sale {
  id            String        @id @default(uuid())
  amount        Decimal       @db.Decimal(10, 2)
  paymentMethod PaymentMethod
  createdAt     DateTime      @default(now())

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  cashRegisterId String
  cashRegister   CashRegister @relation(fields: [cashRegisterId], references: [id])

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])
}

model Employee {
  id       String  @id @default(uuid())
  name     String
  salary   Decimal @db.Decimal(10, 2)
  isActive Boolean @default(true)
  cpf      String  @unique

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  salaryPayments SalaryPayment[]

  createdAt DateTime @default(now())
}

model SalaryPayment {
  id             String   @id @default(uuid())
  amount         Decimal  @db.Decimal(10, 2)
  paidAt         DateTime @default(now())
  referenceMonth String

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])

  companyId String
  company   Company @relation(fields: [companyId], references: [id])
}

model MonthlyClosure {
  id    String @id @default(uuid())
  month Int
  year  Int

  totalRevenue  Decimal @db.Decimal(12, 2)
  totalExpenses Decimal @db.Decimal(12, 2)
  totalSalaries Decimal @db.Decimal(12, 2)
  profit        Decimal @db.Decimal(12, 2)

  closedAt DateTime @default(now())

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  closedById String
  closedBy   User   @relation(fields: [closedById], references: [id])
}
