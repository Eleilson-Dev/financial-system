{
  "name": "financial-system",
  "packageManager": "yarn@4.11.0",
  "type": "module",
  "scripts": {
    "dev": "dotenv -e .env.dev -- tsx watch src/server.ts",
    "prod": "dotenv -e .env.prod -- tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/src/server.js",
    "migrate:dev": "dotenv -e .env.dev -- prisma migrate dev",
    "migrate:prod": "dotenv -e .env.prod -- prisma migrate deploy"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.2.0",
    "@prisma/client": "^7.2.0",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "dayjs": "^1.11.19",
    "dotenv-cli": "^11.0.0",
    "express": "4",
    "express-async-errors": "^3.1.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.16.3",
    "reflect-metadata": "^0.2.2",
    "socket.io": "^4.8.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "tsyringe": "^4.10.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@types/bcrypt": "^6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9",
    "@types/node": "^25.0.3",
    "@types/pg": "^8",
    "@types/swagger-jsdoc": "^6",
    "@types/swagger-ui-express": "^4.1.8",
    "openapi-types": "^12.1.3",
    "prisma": "^7.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
